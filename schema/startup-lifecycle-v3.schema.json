{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/startup-lifecycle/v3.json",
  "title": "Actutum startup lifecycle evidence v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scope", "evidenceLevel", "outcome", "repetitions", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "samples"],
  "properties": {
    "schemaVersion": { "const": "actutum.startup-lifecycle/v3" },
    "scope": { "const": "fresh-and-immediate-same-profile-startup" },
    "evidenceLevel": { "enum": ["controlled-local-observation", "hosted-runner-evidence"] },
    "outcome": { "enum": ["success", "failure"] },
    "repetitions": { "type": "integer", "minimum": 1, "maximum": 100 },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": { "$ref": "#/$defs/environment" },
    "measurement": { "$ref": "#/$defs/measurement" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/$defs/sample" }
    }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "webView2Version", "runnerImage", "runnerImageVersion", "githubRunId", "githubRunAttempt", "gitCommit"],
      "properties": {
        "os": { "const": "windows" },
        "architecture": { "const": "amd64" },
        "webView2Version": { "type": "string", "minLength": 1 },
        "runnerImage": { "type": ["string", "null"] },
        "runnerImageVersion": { "type": ["string", "null"] },
        "githubRunId": { "type": ["string", "null"] },
        "githubRunAttempt": { "type": ["string", "null"] },
        "gitCommit": { "type": ["string", "null"] }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "toolVersion", "unit", "clock", "concurrency", "freshProfilePerSample", "immediateRelaunch", "readyBoundary", "browserExitBoundary", "profileReleaseBoundary", "hostExitTimeoutMs", "browserExitTimeoutMs", "profileReleaseTimeoutMs"],
      "properties": {
        "tool": { "const": "tests/startup/TestStartupLifecycleEvidence" },
        "toolVersion": { "const": 2 },
        "unit": { "const": "milliseconds" },
        "clock": { "const": "time.Time-with-process-local-monotonic-component" },
        "concurrency": { "const": 1 },
        "freshProfilePerSample": { "const": true },
        "immediateRelaunch": { "const": true },
        "readyBoundary": { "const": "process-start-to-domcontentloaded-plus-two-animation-frames" },
        "browserExitBoundary": { "const": "host-exit-to-signaled-main-browser-process-handle" },
        "profileReleaseBoundary": { "const": "immediate-host-exit-to-successful-user-data-folder-removal" },
        "hostExitTimeoutMs": { "const": 5000 },
        "browserExitTimeoutMs": { "const": 10000 },
        "profileReleaseTimeoutMs": { "const": 10000 }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "elapsedMs"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "elapsedMs": { "type": "number", "minimum": 0 }
      }
    },
    "startupTimeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "clock", "phases"],
      "properties": {
        "schemaVersion": { "const": "actutum.host-startup-timeline/v1" },
        "clock": { "const": "time-since-host-entry-monotonic" },
        "phases": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "items": {
            "allOf": [
              { "$ref": "#/$defs/phase" },
              { "properties": { "name": { "enum": ["host-entry", "config-loaded", "runtime-open-started", "window-create-started", "environment-create-started", "environment-created", "controller-created", "webview-created", "navigation-dispatched", "runtime-opened", "dom-2raf"] } } }
            ]
          }
        }
      }
    },
    "shutdownTimeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "clock", "phases"],
      "properties": {
        "schemaVersion": { "const": "actutum.host-shutdown-timeline/v1" },
        "clock": { "const": "time-since-shutdown-request-monotonic" },
        "phases": {
          "type": "array",
          "minItems": 13,
          "maxItems": 13,
          "items": {
            "allOf": [
              { "$ref": "#/$defs/phase" },
              { "properties": { "name": { "enum": ["shutdown-requested", "dispatcher-closed", "destroy-queued", "destroy-dispatched", "window-close-dispatched", "chromium-destroy-entered", "event-handlers-removed", "controller-closed", "webview-released", "controller-released", "environment-released", "window-destroyed", "run-loop-exited"] } } }
            ]
          }
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["readyMs", "hostExitMs", "browserProcessId", "browserExitAfterHostMs", "startupTimeline", "shutdownTimeline"],
      "properties": {
        "readyMs": { "type": "number", "minimum": 0 },
        "hostExitMs": { "type": "number", "minimum": 0 },
        "browserProcessId": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "browserExitAfterHostMs": { "type": "number", "minimum": 0 },
        "startupTimeline": { "$ref": "#/$defs/startupTimeline" },
        "shutdownTimeline": { "$ref": "#/$defs/shutdownTimeline" }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "code"],
      "properties": {
        "phase": { "enum": ["profile-create", "first-launch", "immediate-launch", "first-browser-exit", "immediate-browser-exit", "profile-release"] },
        "code": { "enum": ["PROFILE_CREATE_FAILED", "HOST_RUN_FAILED", "BROWSER_EXIT_FAILED", "PROFILE_RELEASE_FAILED"] }
      }
    },
    "crossProcessTimeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["immediateProcessStartAfterFirstHostExitMs", "firstBrowserExitAfterImmediateStartMs", "immediateReadyAfterFirstBrowserExitMs", "immediateReadyWaitedForFirstBrowserExit"],
      "properties": {
        "immediateProcessStartAfterFirstHostExitMs": { "type": "number" },
        "firstBrowserExitAfterImmediateStartMs": { "type": "number" },
        "immediateReadyAfterFirstBrowserExitMs": { "type": "number" },
        "immediateReadyWaitedForFirstBrowserExit": { "type": "boolean" }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "outcome", "first", "immediate", "profileReleaseMs", "timeline", "error"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "outcome": { "enum": ["success", "failure"] },
        "first": { "oneOf": [{ "$ref": "#/$defs/launch" }, { "type": "null" }] },
        "immediate": { "oneOf": [{ "$ref": "#/$defs/launch" }, { "type": "null" }] },
        "profileReleaseMs": { "type": ["number", "null"], "minimum": 0 },
        "timeline": { "oneOf": [{ "$ref": "#/$defs/crossProcessTimeline" }, { "type": "null" }] },
        "error": { "oneOf": [{ "$ref": "#/$defs/error" }, { "type": "null" }] }
      },
      "allOf": [{
        "if": { "properties": { "outcome": { "const": "success" } } },
        "then": { "properties": { "first": { "$ref": "#/$defs/launch" }, "immediate": { "$ref": "#/$defs/launch" }, "profileReleaseMs": { "type": "number" }, "timeline": { "$ref": "#/$defs/crossProcessTimeline" }, "error": { "type": "null" } } },
        "else": { "properties": { "error": { "$ref": "#/$defs/error" } } }
      }]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": {
        "properties": {
          "samples": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/sample" },
                { "properties": { "outcome": { "const": "success" } } }
              ]
            }
          }
        }
      },
      "else": {
        "properties": {
          "samples": {
            "contains": { "properties": { "outcome": { "const": "failure" } } },
            "minContains": 1
          }
        }
      }
    },
    {
      "if": { "properties": { "evidenceLevel": { "const": "hosted-runner-evidence" } } },
      "then": {
        "properties": {
          "environment": {
            "properties": {
              "runnerImage": { "type": "string", "minLength": 1 },
              "runnerImageVersion": { "type": "string", "minLength": 1 },
              "githubRunId": { "type": "string", "minLength": 1 },
              "githubRunAttempt": { "type": "string", "minLength": 1 },
              "gitCommit": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" }
            }
          }
        }
      }
    }
  ]
}
