{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/ipc/v1.json",
  "title": "Actutum IPC v1",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "id", "method", "params"],
      "properties": {
        "v": { "const": 1 },
        "id": { "type": "integer", "minimum": 1, "maximum": 4294967295 },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "id", "ok"],
      "properties": {
        "v": { "const": 1 },
        "id": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "ok": { "type": "boolean" },
        "result": {},
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "ok": { "const": true } } },
          "then": { "not": { "required": ["error"] } },
          "else": { "required": ["error"] }
        }
      ]
    }
  }
}
