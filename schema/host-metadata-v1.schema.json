{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/host-metadata/v1.json",
  "title": "Velox host metadata v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "releaseVersion", "target", "contracts", "host"],
  "properties": {
    "schemaVersion": { "const": "velox.host/v1" },
    "releaseVersion": { "type": "string", "minLength": 1 },
    "target": { "const": "windows-x64" },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "runtime", "ipc"],
      "properties": {
        "host": { "const": 1 },
        "runtime": { "const": 1 },
        "ipc": { "const": 1 }
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "bytes", "sha256"],
      "properties": {
        "file": { "const": "velox-host.exe" },
        "bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
