{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0disoft.dev/actutum/consumer-clean-v1.schema.json",
  "title": "Actutum checkout-free consumer smoke result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sourceCommit", "acquisitionMode", "releaseSha256", "startedAtUtc", "finishedAtUtc", "endToEndMs", "firstBuildSha256", "secondBuildSha256", "deterministic", "invokedTools"],
  "properties": {
    "schemaVersion": { "const": "actutum.consumer-clean/v1" },
    "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "acquisitionMode": { "const": "github-actions-artifact-no-checkout" },
    "releaseSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "endToEndMs": { "type": "number", "minimum": 0 },
    "firstBuildSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "secondBuildSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "deterministic": { "const": true },
    "invokedTools": { "const": ["actutum.exe"] }
  }
}
