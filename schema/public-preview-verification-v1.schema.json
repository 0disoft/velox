{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0disoft.dev/velox/public-preview-verification-v1.schema.json",
  "title": "Velox public developer-preview verification result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "releaseTag",
    "releaseVersion",
    "releaseUrl",
    "acquisitionMode",
    "expectedReleaseSha256",
    "observedReleaseSha256",
    "checksumsVerified",
    "sbomVerified",
    "provenanceVerified",
    "deterministicBuild",
    "doctorReady",
    "startupReady",
    "startedAtUtc",
    "finishedAtUtc",
    "endToEndMs",
    "evidenceLevel",
    "externalUserAttempt",
    "invokedTools",
    "environment"
  ],
  "properties": {
    "schemaVersion": { "const": "velox.public-preview-verification/v1" },
    "repository": { "const": "0disoft/velox" },
    "releaseTag": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+-alpha\\.[1-9][0-9]*$" },
    "releaseVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-alpha\\.[1-9][0-9]*$" },
    "releaseUrl": { "type": "string", "format": "uri" },
    "acquisitionMode": { "const": "github-release-public-url-no-checkout" },
    "expectedReleaseSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "observedReleaseSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "checksumsVerified": { "const": true },
    "sbomVerified": { "const": true },
    "provenanceVerified": { "const": true },
    "deterministicBuild": { "const": true },
    "doctorReady": { "const": true },
    "startupReady": { "const": true },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "endToEndMs": { "type": "number", "minimum": 0 },
    "evidenceLevel": { "const": "same-repository-public-download" },
    "externalUserAttempt": { "const": false },
    "invokedTools": { "const": ["velox.exe"] },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runnerImage", "runnerImageVersion", "architecture", "githubRunId", "githubRunAttempt"],
      "properties": {
        "runnerImage": { "type": "string", "minLength": 1 },
        "runnerImageVersion": { "type": "string", "minLength": 1 },
        "architecture": { "const": "AMD64" },
        "githubRunId": { "type": "string", "minLength": 1 },
        "githubRunAttempt": { "type": "string", "minLength": 1 }
      }
    }
  }
}
