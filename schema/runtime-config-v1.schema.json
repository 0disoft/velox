{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.velox.invalid/runtime-config/v1.json",
  "title": "Velox runtime configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["runtimeVersion", "app", "assets", "window", "security"],
  "properties": {
    "runtimeVersion": { "const": 1 },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9](?:[a-z0-9-]*[a-z0-9])?)+$"
        },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "entry"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "entry": { "type": "string", "minLength": 1 }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 320 },
        "height": { "type": "integer", "minimum": 240 }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["permissions"],
      "properties": {
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["app.info", "window.basic"] }
        }
      }
    }
  }
}
