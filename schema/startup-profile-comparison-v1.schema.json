{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.actutum.invalid/startup-profile-comparison/v1.json",
  "title": "Actutum startup profile comparison v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scope", "evidenceLevel", "outcome", "repetitions", "startedAtUtc", "finishedAtUtc", "environment", "measurement", "samples", "summary"],
  "properties": {
    "schemaVersion": { "const": "actutum.startup-profile-comparison/v1" },
    "scope": { "const": "same-profile-versus-fresh-profile-immediate-relaunch" },
    "evidenceLevel": { "enum": ["controlled-local-observation", "hosted-runner-evidence"] },
    "outcome": { "enum": ["success", "failure"] },
    "repetitions": { "type": "integer", "minimum": 1, "maximum": 10 },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "environment": { "$ref": "#/$defs/environment" },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "toolVersion", "unit", "readyBoundary", "alternatingTrialOrder", "concurrentTrials"],
      "properties": {
        "tool": { "const": "tests/startup/TestStartupProfileComparisonEvidence" },
        "toolVersion": { "const": 1 },
        "unit": { "const": "milliseconds" },
        "readyBoundary": { "const": "process-start-to-domcontentloaded-plus-two-animation-frames" },
        "alternatingTrialOrder": { "const": true },
        "concurrentTrials": { "const": false }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/sample" }
    },
    "summary": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["successfulPairs", "sameProfileSecondP50Ms", "freshProfileSecondP50Ms", "p50DeltaMs"],
          "properties": {
            "successfulPairs": { "type": "integer", "minimum": 1, "maximum": 10 },
            "sameProfileSecondP50Ms": { "type": "number", "minimum": 0 },
            "freshProfileSecondP50Ms": { "type": "number", "minimum": 0 },
            "p50DeltaMs": { "type": "number" }
          }
        },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "webView2Version", "runnerImage", "runnerImageVersion", "githubRunId", "githubRunAttempt", "gitCommit"],
      "properties": {
        "os": { "const": "windows" },
        "architecture": { "const": "amd64" },
        "webView2Version": { "type": "string", "minLength": 1 },
        "runnerImage": { "type": ["string", "null"] },
        "runnerImageVersion": { "type": ["string", "null"] },
        "githubRunId": { "type": ["string", "null"] },
        "githubRunAttempt": { "type": ["string", "null"] },
        "gitCommit": { "type": ["string", "null"] }
      }
    },
    "trial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "firstReadyMs", "secondReadyMs", "firstBrowserExitAfterSecondStartMs", "secondReadyAfterFirstBrowserExitMs", "secondReadyWaitedForFirstBrowserExit", "secondBrowserExitAfterSecondHostExitMs"],
      "properties": {
        "mode": { "enum": ["same-profile", "fresh-profile"] },
        "firstReadyMs": { "type": "number", "minimum": 0 },
        "secondReadyMs": { "type": "number", "minimum": 0 },
        "firstBrowserExitAfterSecondStartMs": { "type": "number" },
        "secondReadyAfterFirstBrowserExitMs": { "type": "number" },
        "secondReadyWaitedForFirstBrowserExit": { "type": "boolean" },
        "secondBrowserExitAfterSecondHostExitMs": { "type": "number", "minimum": 0 }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "code"],
      "properties": {
        "phase": { "enum": ["same-profile", "fresh-profile"] },
        "code": { "const": "TRIAL_FAILED" }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "outcome", "order", "sameProfile", "freshProfile", "error"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "outcome": { "enum": ["success", "failure"] },
        "order": {
          "oneOf": [
            { "const": ["same-profile", "fresh-profile"] },
            { "const": ["fresh-profile", "same-profile"] }
          ]
        },
        "sameProfile": { "oneOf": [{ "$ref": "#/$defs/trial" }, { "type": "null" }] },
        "freshProfile": { "oneOf": [{ "$ref": "#/$defs/trial" }, { "type": "null" }] },
        "error": { "oneOf": [{ "$ref": "#/$defs/error" }, { "type": "null" }] }
      },
      "allOf": [
        {
          "if": { "properties": { "outcome": { "const": "success" } } },
          "then": {
            "properties": {
              "sameProfile": { "$ref": "#/$defs/trial" },
              "freshProfile": { "$ref": "#/$defs/trial" },
              "error": { "type": "null" }
            }
          },
          "else": { "properties": { "error": { "$ref": "#/$defs/error" } } }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "success" } } },
      "then": {
        "properties": {
          "summary": { "type": "object" },
          "samples": { "items": { "allOf": [{ "$ref": "#/$defs/sample" }, { "properties": { "outcome": { "const": "success" } } }] } }
        }
      }
    }
  ]
}
